rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inspirations
    // Document ID: auto-generated
    // Fields:
    //   - imageUrl: string (required) - The URL of the generated image.
    //   - location: string (required) - The destination city or country.
    //   - season: string (optional) - The season of the destination.
    //   - style: string (required) - The aesthetic style of the outfit.
    //   - attire: string (required) - The attire preference.
    //   - createdAt: timestamp (required) - When this inspiration was generated.
    //   - creatorUid: string (required) - Anonymous Firebase Auth UID that created it.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidHostedImageUrl(url) {
      return url.matches('^https://[^\\s]+$');
    }

    function isValidInlineImage(url) {
      return url.matches('^data:image/(jpeg|jpg|png|webp);base64,[A-Za-z0-9+/=]+$');
    }

    function isValidImageUrl(url) {
      return url is string &&
        (isValidHostedImageUrl(url) || isValidInlineImage(url));
    }

    function isSafeShortString(value, maxLength) {
      return value is string &&
        value.size() > 0 &&
        value.size() <= maxLength &&
        !value.matches('.*[<>].*');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidInspiration(data) {
      return hasRequiredFields(['imageUrl', 'location', 'style', 'attire', 'createdAt', 'creatorUid']) &&
             hasOnlyAllowedFields(['imageUrl', 'location', 'season', 'style', 'attire', 'createdAt', 'creatorUid']) &&
             isValidImageUrl(data.imageUrl) && data.imageUrl.size() <= 200000 &&
             isSafeShortString(data.location, 100) &&
             (!('season' in data) || isSafeShortString(data.season, 50)) &&
             isSafeShortString(data.style, 50) &&
             isSafeShortString(data.attire, 50) &&
             data.createdAt == request.time &&
             data.creatorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /inspirations/{inspirationId} {
      // Anyone can read sanitized, immutable past inspirations for the carousel
      allow read: if true;
      
      // Anonymous Auth plus strict payload validation prevents unauthenticated spam and unsafe image payloads
      allow create: if isAuthenticated() && isValidInspiration(request.resource.data);
      
      // Inspirations are immutable once created
      allow update, delete: if false;
    }
  }
}
