rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inspirations
    // Document ID: auto-generated
    // Fields:
    //   - imageUrl: string (required) - The URL of the generated image.
    //   - location: string (required) - The destination city or country.
    //   - season: string (optional) - The season of the destination.
    //   - style: string (required) - The aesthetic style of the outfit.
    //   - attire: string (required) - The attire preference.
    //   - createdAt: timestamp (required) - When this inspiration was generated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrlOrBase64(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*") || url.matches('^data:image/.*'));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidInspiration(data) {
      return hasOnlyAllowedFields(['imageUrl', 'location', 'season', 'style', 'attire', 'createdAt']) &&
             data.imageUrl is string && isValidUrlOrBase64(data.imageUrl) && data.imageUrl.size() < 400000 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 100 &&
             (!('season' in data) || (data.season is string && data.season.size() < 50)) &&
             data.style is string && data.style.size() > 0 && data.style.size() < 50 &&
             data.attire is string && data.attire.size() > 0 && data.attire.size() < 50 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /inspirations/{inspirationId} {
      // Anyone can read past inspirations for the carousel
      allow read: if true;
      
      // Allow creation by any user, as we rely strictly on payload validation without user authentication in this app
      allow create: if isValidInspiration(request.resource.data);
      
      // Inspirations are immutable once created
      allow update, delete: if false;
    }
  }
}
